// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CREATOR
  UPLOADER
}

enum TaskStatus {
  AWAITING_REACTION // Свободна для всех
  IN_PROGRESS       // Креатор взял в работу
  REACTION_UPLOADED // Реакция загружена
  PUBLISHED         // Опубликовано
  ERROR             // Ошибка
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   // "ADMIN", "MANAGER", "CREATOR"
  tgUsername String?
  lastActive DateTime?
  
  // Отношения
  tasks      Task[]   @relation("CreatorTasks")
  uploads    Task[]   @relation("UploaderTasks")
  managed    Task[]   @relation("ManagerTasks") // Задачи, созданные этим менеджером
  createdAt  DateTime @default(now())
  pushSubscriptions PushSubscription[]

  notifications Notification[]
  preference    UserPreference?
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  taskId    Int?
  targetTab String?  // Добавляем это поле (например: "my", "available", "history", "active")
  title     String
  message   String
  type      String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UserPreference {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique
  user      User    @relation(fields: [userId], references: [id])
  enabled   Boolean @default(true) // Единственная настройка: Вкл/Выкл всё
}

model PushSubscription {
  id        Int    @id @default(autoincrement())
  userId    Int
  user      User   @relation(fields: [userId], references: [id])
  endpoint  String @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Channel {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  titlePrefix         String?  @default("")
  descriptionFooter   String?  @default("")
  showOriginalLink    Boolean  @default(true)
  originalLinkPrefix  String?  @default("CREDIT - ")
  tasks              Task[]
  createdAt          DateTime @default(now())
}

// Таблица для глобальных настроек (прокси и т.д.)
model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique // например, "proxy_url"
  value String
}

model OriginalVideo {
  id            Int      @id @default(autoincrement())
  videoId       String   @unique
  url           String   
  title         String?
  duration      Int?
  filePath      String?
  thumbnailPath String?
  errorMessage  String?  
  status        String   @default("DOWNLOADING") 
  tasks         Task[]
  createdAt     DateTime @default(now())
}

model Task {
  id               Int            @id @default(autoincrement())
  
  // Связь с оригиналом
  originalVideoId  Int            
  originalVideo    OriginalVideo  @relation(fields: [originalVideoId], references: [id])
  
  priority         String         @default("normal")
  status           TaskStatus     @default(AWAITING_REACTION)
  
  // ОТВЕТНАЯ ЧАСТЬ ДЛЯ КРЕАТОРА
  creatorId        Int?
  creator          User?          @relation("CreatorTasks", fields: [creatorId], references: [id])

  // ОТВЕТНАЯ ЧАСТЬ ДЛЯ ЗАГРУЗЧИКА (Исправление ошибки!)
  uploaderId       Int?
  uploader         User?          @relation("UploaderTasks", fields: [uploaderId], references: [id])

  managerId        Int?
  manager          User?          @relation("ManagerTasks", fields: [managerId], references: [id])

  channelId        Int
  channel          Channel        @relation(fields: [channelId], references: [id])

  // Таймлайны (Твои новые поля)
  createdAt        DateTime       @default(now())      // Добавлено в ленту
  claimedAt        DateTime?                           // Взято в работу
  reactionUploadedAt DateTime?                         // Реакция готова
  publishedAt      DateTime?                           // Опубликовано на YouTube
  deadline         DateTime?                           // Срок (дедлайн)

  reactionFilePath String?
  youtubeUrl       String?
  scheduledAt      DateTime?
    
  needsFixing      Boolean        @default(false)
  rejectionReason  String?
  updatedAt        DateTime       @updatedAt
}